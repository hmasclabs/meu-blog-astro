---
import { readData } from '../lib/readData';

const siteConfig = readData('siteConfig.json', {
  name: 'Meu Blog',
  description: 'Um blog incrível.',
  social: {},
}) as any;

const currentYear = new Date().getFullYear();
---

<footer class="bg-gray-900 border-t border-gray-800 pt-16 pb-8">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-12 mb-12">
      <!-- Brand -->
      <div class="col-span-1 md:col-span-2">
        <a href="/" class="text-2xl font-bold text-white tracking-tight flex items-center gap-2 mb-4" style="font-family: var(--font-heading);">
          {siteConfig.logo ? (
            <img src={siteConfig.logo} alt={siteConfig.name} class="h-9 w-auto" />
          ) : (
            <>
              <span class="w-8 h-8 rounded-lg bg-blue-500 flex items-center justify-center text-white font-bold text-sm">
                {siteConfig.name?.charAt(0) || 'B'}
              </span>
              {siteConfig.name || 'Blog'}
            </>
          )}
        </a>
        <p class="text-gray-400 text-sm leading-relaxed mb-6 max-w-xs">
          {siteConfig.footer?.description || siteConfig.description || 'Compartilhando conhecimento e inspiração.'}
        </p>
        <!-- Social icons -->
        <div class="flex gap-4">
          {siteConfig.social?.facebook && (
            <a href={siteConfig.social.facebook} target="_blank" rel="noopener" class="text-gray-500 hover:text-white transition-colors">
              <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
            </a>
          )}
          {siteConfig.social?.twitter && (
            <a href={siteConfig.social.twitter} target="_blank" rel="noopener" class="text-gray-500 hover:text-white transition-colors">
              <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24"><path d="M8.29 20.251c7.547 0 11.675-6.253 11.675-11.675 0-.178 0-.355-.012-.53A8.348 8.348 0 0022 5.92a8.19 8.19 0 01-2.357.646 4.118 4.118 0 001.804-2.27 8.224 8.224 0 01-2.605.996 4.107 4.107 0 00-6.993 3.743 11.65 11.65 0 01-8.457-4.287 4.106 4.106 0 001.27 5.477A4.072 4.072 0 012.8 9.713v.052a4.105 4.105 0 003.292 4.022 4.095 4.095 0 01-1.853.07 4.108 4.108 0 003.834 2.85A8.233 8.233 0 012 18.407a11.616 11.616 0 006.29 1.84"/></svg>
            </a>
          )}
          {siteConfig.social?.instagram && (
            <a href={siteConfig.social.instagram} target="_blank" rel="noopener" class="text-gray-500 hover:text-pink-400 transition-colors">
              <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
            </a>
          )}
          {siteConfig.social?.youtube && (
            <a href={siteConfig.social.youtube} target="_blank" rel="noopener" class="text-gray-500 hover:text-red-500 transition-colors">
              <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24"><path d="M23.495 6.205a3.007 3.007 0 00-2.088-2.088c-1.87-.501-9.396-.501-9.396-.501s-7.507-.01-9.396.501A3.007 3.007 0 00.527 6.205a31.247 31.247 0 00-.522 5.805 31.247 31.247 0 00.522 5.783 3.007 3.007 0 002.088 2.088c1.868.502 9.396.502 9.396.502s7.506 0 9.396-.502a3.007 3.007 0 002.088-2.088 31.247 31.247 0 00.5-5.783 31.247 31.247 0 00-.5-5.805zM9.609 15.601V8.408l6.264 3.602z"/></svg>
            </a>
          )}
          {siteConfig.social?.pinterest && (
            <a href={siteConfig.social.pinterest} target="_blank" rel="noopener" class="text-gray-500 hover:text-red-400 transition-colors">
              <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0C5.373 0 0 5.373 0 12c0 5.084 3.163 9.426 7.627 11.174-.105-.949-.2-2.405.042-3.441.218-.937 1.407-5.965 1.407-5.965s-.359-.719-.359-1.782c0-1.668.967-2.914 2.171-2.914 1.023 0 1.518.769 1.518 1.69 0 1.029-.655 2.568-.994 3.995-.283 1.194.599 2.169 1.777 2.169 2.133 0 3.772-2.249 3.772-5.495 0-2.873-2.064-4.882-5.012-4.882-3.414 0-5.418 2.561-5.418 5.207 0 1.031.397 2.138.893 2.738a.36.36 0 01.083.345l-.333 1.36c-.053.22-.174.267-.402.161-1.499-.698-2.436-2.889-2.436-4.649 0-3.785 2.75-7.262 7.929-7.262 4.163 0 7.398 2.967 7.398 6.931 0 4.136-2.607 7.464-6.227 7.464-1.216 0-2.359-.632-2.75-1.378l-.748 2.853c-.271 1.043-1.002 2.35-1.492 3.146C9.57 23.812 10.763 24 12 24c6.627 0 12-5.373 12-12S18.627 0 12 0z"/></svg>
            </a>
          )}
        </div>
      </div>

      <!-- Links -->
      <div>
        <h3 class="text-sm font-semibold text-white tracking-wider uppercase mb-4">Navegação</h3>
        <ul class="space-y-3">
          <li><a href="/" class="text-sm text-gray-400 hover:text-blue-400 transition-colors">Home</a></li>
          <li><a href="/blog" class="text-sm text-gray-400 hover:text-blue-400 transition-colors">Blog</a></li>
          <li><a href="/artigos" class="text-sm text-gray-400 hover:text-blue-400 transition-colors">Artigos</a></li>
          <li><a href="/sobre" class="text-sm text-gray-400 hover:text-blue-400 transition-colors">Sobre</a></li>
          <li><a href="/contato" class="text-sm text-gray-400 hover:text-blue-400 transition-colors">Contato</a></li>
        </ul>
      </div>

      <!-- Legal -->
      <div>
        <h3 class="text-sm font-semibold text-white tracking-wider uppercase mb-4">Legal</h3>
        <ul class="space-y-3">
          <li><a href="/privacidade" class="text-sm text-gray-400 hover:text-blue-400 transition-colors">Privacidade</a></li>
          <li><a href="/termos" class="text-sm text-gray-400 hover:text-blue-400 transition-colors">Termos de Uso</a></li>
        </ul>
      </div>
    </div>

    <div class="border-t border-gray-800 pt-8 flex flex-col md:flex-row justify-between items-center gap-4">
      <p class="text-sm text-gray-500 text-center md:text-left w-full text-center">
        &copy; {currentYear} {siteConfig.footer?.copyright || siteConfig.name || 'Blog'}. Todos os direitos reservados.
      </p>
    </div>
  </div>
</footer>
