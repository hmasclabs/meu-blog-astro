---
import { getCollection } from 'astro:content';
import { readData } from '../lib/readData';

const siteConfig = readData('siteConfig.json', {
  name: 'Meu Blog',
  logo: '',
  social: {}
}) as any;

const categoriesData = readData('categories.json', []) as any[];
const menuItems = readData('menu.json', { items: [] }).items as any[];

const posts = await getCollection('blog');
const categoriesFromPosts = [...new Set(posts.map((p: any) => p.data.category).filter(Boolean))];
const allCategories: string[] = categoriesData.length > 0 ? categoriesData : categoriesFromPosts as string[];
---

<header class="bg-white border-b border-gray-100 sticky top-0 z-50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex justify-between items-center h-20">
      <!-- Logo -->
      <div class="flex-shrink-0 flex items-center">
        <a href="/" class="text-2xl font-bold text-gray-900 tracking-tight flex items-center gap-2">
          {siteConfig.logo ? (
            <img src={siteConfig.logo} alt={siteConfig.name} class="h-9 w-auto" />
          ) : (
            <>
              <span class="w-8 h-8 rounded-lg bg-blue-600 flex items-center justify-center text-white font-bold text-sm">
                {siteConfig.name?.charAt(0) || 'B'}
              </span>
              <span style="font-family: var(--font-heading);">{siteConfig.name || 'Blog'}</span>
            </>
          )}
        </a>
      </div>

      <!-- Desktop Menu -->
      <nav class="hidden md:flex space-x-1 items-center">
        {menuItems.length > 0 ? menuItems.map((item: any) => (
          item.showCategories ? (
            <div class="group relative inline-block">
              <a href={item.href} class="text-gray-600 hover:text-blue-600 px-3 py-2 text-sm font-medium transition-colors inline-flex items-center rounded-lg hover:bg-gray-50">
                {item.label}
                <svg class="ml-1 w-4 h-4 transition-transform group-hover:-rotate-180 duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
              </a>
              <div class="opacity-0 invisible group-hover:opacity-100 group-hover:visible absolute left-0 mt-0 pt-2 w-52 transition-all duration-200 z-50">
                <div class="bg-white rounded-xl shadow-xl border border-gray-100 py-2 overflow-hidden">
                  {allCategories.map((cat: string) => (
                    <a href={`/categoria/${cat.toLowerCase().replace(/[^a-z0-9]/g, '-')}`}
                      class="block px-5 py-2.5 text-sm text-gray-600 hover:bg-blue-50 hover:text-blue-700 transition-colors">
                      {cat}
                    </a>
                  ))}
                  <div class="border-t border-gray-100 mt-1 pt-1">
                    <a href="/blog" class="block px-5 py-2 text-xs font-semibold text-blue-600 uppercase tracking-wider hover:bg-gray-50">
                      Ver todos
                    </a>
                  </div>
                </div>
              </div>
            </div>
          ) : (
            <a href={item.href} target={item.href.startsWith('http') ? '_blank' : undefined} class="text-gray-600 hover:text-blue-600 px-3 py-2 text-sm font-medium transition-colors rounded-lg hover:bg-gray-50">{item.label}</a>
          )
        )) : (
          <>
            <a href="/" class="text-gray-600 hover:text-blue-600 px-3 py-2 text-sm font-medium transition-colors rounded-lg hover:bg-gray-50">Home</a>
            <a href="/blog" class="text-gray-600 hover:text-blue-600 px-3 py-2 text-sm font-medium transition-colors rounded-lg hover:bg-gray-50">Blog</a>
            <a href="/sobre" class="text-gray-600 hover:text-blue-600 px-3 py-2 text-sm font-medium transition-colors rounded-lg hover:bg-gray-50">Sobre</a>
            <a href="/contato" class="text-gray-600 hover:text-blue-600 px-3 py-2 text-sm font-medium transition-colors rounded-lg hover:bg-gray-50">Contato</a>
          </>
        )}
      </nav>

      <!-- Right side -->
      <div class="hidden md:flex items-center gap-3">
        {siteConfig.social?.instagram && (
          <a href={siteConfig.social.instagram} target="_blank" rel="noopener" class="text-gray-400 hover:text-pink-500 transition-colors">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
          </a>
        )}
        <a href="https://wa.me/5591981992265" target="_blank" rel="noopener noreferrer" class="bg-[#25D366] hover:bg-[#1DA851] text-white px-5 py-2 rounded-full text-sm font-bold transition-all shadow-sm flex items-center gap-2">
          <svg class="w-4 h-4 fill-current" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51a12.8 12.8 0 0 0-.57-.01c-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.052 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413Z"/></svg>
          Começar!
        </a>
      </div>

      <!-- Mobile menu button -->
      <div class="flex items-center gap-2 md:hidden">
        <a href="https://wa.me/5591981992265" target="_blank" rel="noopener noreferrer" class="bg-[#25D366] hover:bg-[#1DA851] text-white px-3 py-1.5 rounded-full text-xs font-bold transition-all shadow-sm flex items-center gap-1.5">
          <svg class="w-3.5 h-3.5 fill-current" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51a12.8 12.8 0 0 0-.57-.01c-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.052 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413Z"/></svg>
          Começar!
        </a>
        <button id="mobile-menu-btn" type="button" class="inline-flex items-center justify-center p-2 rounded-md text-gray-400 hover:text-gray-500 hover:bg-gray-100 focus:outline-none">
          <span class="sr-only">Abrir menu</span>
          <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
        </button>
      </div>
    </div>

    <!-- Mobile Menu -->
    <div id="mobile-menu" class="hidden md:hidden pb-4">
      <div class="flex flex-col gap-1">
        {menuItems.length > 0 ? menuItems.map((item: any) => (
          <a href={item.href} target={item.href.startsWith('http') ? '_blank' : undefined} class="text-gray-600 hover:text-blue-600 px-3 py-2 text-sm font-medium rounded-lg hover:bg-gray-50">{item.label}</a>
        )) : (
          <>
            <a href="/" class="text-gray-600 hover:text-blue-600 px-3 py-2 text-sm font-medium rounded-lg hover:bg-gray-50">Home</a>
            <a href="/blog" class="text-gray-600 hover:text-blue-600 px-3 py-2 text-sm font-medium rounded-lg hover:bg-gray-50">Blog</a>
            <a href="/sobre" class="text-gray-600 hover:text-blue-600 px-3 py-2 text-sm font-medium rounded-lg hover:bg-gray-50">Sobre</a>
            <a href="/contato" class="text-gray-600 hover:text-blue-600 px-3 py-2 text-sm font-medium rounded-lg hover:bg-gray-50">Contato</a>
          </>
        )}
      </div>
    </div>
  </div>
</header>

<script is:inline>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  if (btn && menu) {
    btn.addEventListener('click', () => menu.classList.toggle('hidden'));
  }
</script>
