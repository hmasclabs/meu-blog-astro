---
import { readData } from '../../lib/readData';

const homeConfig = readData('home.json', {}) as any;
const hero = homeConfig.hero || {
    title: 'Construa uma <span style="color: rgb(var(--color-primary));">Nova Renda</span> no Piloto Automático.',
    subtitle: 'Descubra o sistema exato para atrair parceiros e escalar o seu negócio usando um funil de recrutamento 100% automático e duplicável.',
    image: '/profile.png',
    buttonText: 'Quero Começar Agora',
    buttonLink: 'https://wa.me/5591981992265'
};
---

<section class="max-w-6xl mx-auto px-4 py-12 md:py-20 flex flex-col md:flex-row items-center gap-12">
    <div class="flex-1 text-center md:text-left">
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-black text-slate-800 leading-tight" style="font-family: var(--font-heading);" set:html={hero.title}>
        </h1>
        <p class="mt-6 text-xl text-slate-500 font-medium leading-relaxed" style="font-family: var(--font-body);">
            {hero.subtitle}
        </p>
        <div class="mt-8 flex flex-col sm:flex-row gap-4 justify-center md:justify-start">
            <a href={hero.buttonLink} target="_blank" rel="noopener noreferrer" class="btn-primary py-3 px-8 text-lg rounded-full shadow-lg hover:-translate-y-1 transition-transform flex items-center justify-center gap-2">
              <svg class="w-5 h-5 fill-current" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51a12.8 12.8 0 0 0-.57-.01c-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.052 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413Z"/></svg>
              {hero.buttonText}
            </a>
        </div>
    </div>
    <div class="flex-shrink-0 w-56 h-56 md:w-80 md:h-80 rounded-full overflow-hidden border-8 border-white shadow-2xl relative">
        <img src={hero.image} alt="Minha Foto" class="w-full h-full object-cover" onerror="this.src='https://ui-avatars.com/api/?name=Eu&background=random&size=512'" />
    </div>
</section>
