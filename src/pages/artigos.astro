---
import BaseLayout from '../layouts/BaseLayout.astro';
import { posts } from '../utils/posts';
---

<BaseLayout 
  title="Artigos - MeuBlog" 
  description="Explore todos os nossos artigos, dicas e tutoriais."
>
  <section class="py-16 sm:py-24 bg-gray-50 min-h-screen">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      
      <div class="text-center mb-16">
        <h1 class="text-4xl font-extrabold text-gray-900 tracking-tight sm:text-5xl">
          Todos os Artigos
        </h1>
        <p class="mt-4 max-w-2xl text-xl text-gray-500 mx-auto">
          Dicas práticas, tutoriais avançados e histórias reais de sucesso profissional.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-10">
        {posts.map((post) => (
          <article class="flex flex-col bg-white rounded-2xl shadow-sm hover:shadow-xl transition-shadow duration-300 overflow-hidden border border-gray-100 group">
            <a href={`/blog/${post.slug}`} class="flex-shrink-0 relative overflow-hidden block">
              <img class="h-56 w-full object-cover transform group-hover:scale-105 transition-transform duration-500" src={post.image} alt={post.title} />
              <div class="absolute top-4 left-4 bg-white/90 backdrop-blur-sm px-3 py-1 rounded-full text-xs font-semibold text-blue-600 uppercase tracking-wide shadow-sm">
                {post.category}
              </div>
            </a>
            <div class="flex-1 p-6 flex flex-col justify-between">
              <div class="flex-1">
                <a href={`/blog/${post.slug}`} class="block mt-2">
                  <h3 class="text-xl font-bold text-gray-900 group-hover:text-blue-600 transition-colors line-clamp-2">
                    {post.title}
                  </h3>
                  <p class="mt-3 text-base text-gray-500 line-clamp-3 leading-relaxed">
                    {post.excerpt}
                  </p>
                </a>
              </div>
              <div class="mt-6 flex items-center pt-6 border-t border-gray-100">
                <div class="flex-shrink-0">
                  <a href="#">
                    <span class="sr-only">{post.author}</span>
                    <img class="h-10 w-10 rounded-full object-cover ring-2 ring-white" src={post.authorAvatar} alt="" />
                  </a>
                </div>
                <div class="ml-3">
                  <p class="text-sm font-medium text-gray-900">
                    <a href="#" class="hover:underline">{post.author}</a>
                  </p>
                  <div class="flex space-x-1 text-sm text-gray-500">
                    <time datetime={post.date}>{post.date}</time>
                  </div>
                </div>
              </div>
            </div>
          </article>
        ))}
      </div>

    </div>
  </section>
</BaseLayout>
