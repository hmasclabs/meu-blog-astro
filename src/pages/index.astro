---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/home/Hero.astro';
import EditorsPick from '../components/home/EditorsPick.astro';
import StepsSection from '../components/home/StepsSection.astro';
import PostCardStandard from '../components/home/PostCardStandard.astro';
import PostCardCompact from '../components/home/PostCardCompact.astro';
import { getCollection } from 'astro:content';
import { readData } from '../lib/readData';

const siteConfig = readData('siteConfig.json', { name: 'Meu Blog', description: '' }) as any;
const homeConfig = readData('home.json', {}) as any;

const allPosts = await getCollection('blog');
const posts = allPosts.sort(
  (a: any, b: any) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

// Helper to find post by slug (handles Astro v6 .md extensions in id)
const findPost = (slug: string) => {
    if (!slug) return null;
    return posts.find((p: any) => p.id.startsWith(slug));
};

// --- Editor's Pick ---
const epMainSlug = homeConfig?.editorsPick?.mainSlug;
const epMainPost = findPost(epMainSlug) || posts[0];

const epSideSlugs = homeConfig?.editorsPick?.sideSlugs || [];
const epSidePosts = epSideSlugs.map(findPost).filter(Boolean);
const finalEpSidePosts = epSidePosts.length > 0 
    ? epSidePosts 
    : posts.filter((p: any) => p !== epMainPost).slice(0, 3);

// --- Trending ---
const trendingSlugs = homeConfig?.trending?.slugs || [];
const trendingPosts = trendingSlugs.map(findPost).filter(Boolean);
const finalTrending = trendingPosts.length > 0 
    ? trendingPosts 
    : posts.slice(0, 4);

// --- Inspiration ---
const inspirationSlugs = homeConfig?.inspiration?.slugs || [];
const inspirationPosts = inspirationSlugs.map(findPost).filter(Boolean);
const finalInspiration = inspirationPosts.length > 0 
    ? inspirationPosts 
    : posts.slice(1, 5);

// --- Latest Posts ---
const latestLimit = homeConfig?.latestPosts?.limit ?? 6;
// Filter out Editor's Pick main post from latest to avoid immediate duplication
const latestPosts = posts.filter((p: any) => p !== epMainPost).slice(0, latestLimit);
const latestBtnText = homeConfig?.latestPosts?.btnText || 'Ver Todos os Artigos';
const latestBtnLink = homeConfig?.latestPosts?.btnLink || '/blog';
const sectionTitleLatest = homeConfig?.sectionTitles?.latestPosts || 'Publicados Recentemente';
---

<BaseLayout title={siteConfig.name} description={siteConfig.description}>

    <!-- Hero Section -->
    <Hero />

    <!-- Editor's Pick Section -->
    {posts.length > 0 && (
        <div class="bg-slate-50 py-4">
            <EditorsPick mainPost={epMainPost} sidePosts={finalEpSidePosts} />
        </div>
    )}

    <!-- Steps Section (Funnel) -->
    <div class="bg-white py-4">
        <StepsSection />
    </div>

    <!-- Main Content: Two Columns -->
    <section class="max-w-6xl mx-auto px-4 py-16">
        <div class="flex flex-col lg:flex-row gap-12">
            
            <!-- Left Column: Recently Published -->
            <div class="lg:w-2/3 flex-shrink-0 min-w-0">
                <div class="flex items-center justify-between mb-8 pb-4 border-b border-slate-100">
                    <h2 class="text-2xl font-bold text-slate-800" style="font-family: var(--font-heading);">{sectionTitleLatest}</h2>
                    <a href={latestBtnLink} class="text-sm font-bold text-primary hover:underline">{latestBtnText} &rarr;</a>
                </div>

                <div class="flex flex-col gap-10">
                    {latestPosts.map((post: any) => (
                        <PostCardStandard post={post} />
                    ))}
                    {latestPosts.length === 0 && (
                        <p class="text-slate-500">Nenhum artigo encontrado.</p>
                    )}
                </div>
            </div>

            <!-- Right Column: Sidebar (Trending & Inspiration) -->
            <aside class="lg:w-1/3 flex-shrink-0 flex flex-col gap-12">
                
                <!-- Trending -->
                <div>
                    <h2 class="text-xl font-bold text-slate-800 mb-6 pb-2 border-b border-slate-100" style="font-family: var(--font-heading);">
                        Em Alta
                    </h2>
                    <div class="flex flex-col gap-6">
                        {finalTrending.map((post: any, index: number) => (
                            <PostCardCompact post={post} number={index + 1} />
                        ))}
                    </div>
                </div>

                <!-- Inspiration -->
                <div>
                    <h2 class="text-xl font-bold text-slate-800 mb-6 pb-2 border-b border-slate-100" style="font-family: var(--font-heading);">
                        Inspiração
                    </h2>
                    <div class="flex flex-col gap-6">
                        {finalInspiration.map((post: any) => (
                            <PostCardCompact post={post} />
                        ))}
                    </div>
                </div>

            </aside>

        </div>
    </section>

</BaseLayout>
