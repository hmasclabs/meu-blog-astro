---
import BaseLayout from '../layouts/BaseLayout.astro';
import { readData } from '../lib/readData';

const contatoData = readData('contato.json', {
    seo: { title: "Contato", description: "Entre em contato conosco.", image: "" },
    hero: { title: "Fale Conosco", subtitle: "Tem alguma dúvida sobre mentoria ou quer dar um feedback sobre o blog? Preencha o formulário e nossa equipe retornará em breve." },
    cards: { napTitle: "Contatos", addressLabel: "Endereço", phoneLabel: "Telefone", emailLabel: "E-mail", formSubmitText: "Enviar Mensagem no WhatsApp" },
    info: { email: "", phone: "", address: "", whatsapp: "" },
    googleMapsUrl: ""
});

const siteConfig = readData('siteConfig.json', {
    contact: { email: "contato@meublog.com", phone: "+55 (11) 99999-9999", address: "São Paulo, SP - Brasil", whatsapp: "5591981992265" }
});

const email = contatoData.info?.email || siteConfig.contact?.email || "contato@meublog.com";
const phone = contatoData.info?.phone || siteConfig.contact?.phone || siteConfig.phone || "+55 (11) 99999-9999";
const address = contatoData.info?.address || siteConfig.contact?.address || siteConfig.address || "São Paulo, SP - Brasil";
const whatsapp = contatoData.info?.whatsapp || siteConfig.contact?.whatsapp || "5591981992265";
---

<BaseLayout 
  title={contatoData.seo?.title || "Contato - MeuBlog"} 
  description={contatoData.seo?.description || "Entre em contato conosco"}
  image={contatoData.seo?.image}
>
  <div class="bg-gray-50 py-16 sm:py-24 min-h-screen flex items-center">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 w-full">
      
      <div class="bg-white rounded-3xl shadow-xl overflow-hidden flex flex-col md:flex-row">
        
        <!-- Left Side - Info -->
        <div class="bg-blue-600 p-10 md:w-2/5 text-white flex flex-col justify-between">
          <div>
            <h2 class="text-3xl font-extrabold mb-4">{contatoData.hero?.title}</h2>
            <p class="text-blue-100 mb-8 leading-relaxed whitespace-pre-line">
              {contatoData.hero?.subtitle}
            </p>
            
            <div class="space-y-6">
              {email && (
                <div class="flex items-center">
                  <svg class="w-6 h-6 text-blue-200 mr-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path></svg>
                  <span>{email}</span>
                </div>
              )}
              {phone && (
                <div class="flex items-center">
                  <svg class="w-6 h-6 text-blue-200 mr-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path></svg>
                  <span>{phone}</span>
                </div>
              )}
              {address && (
                <div class="flex items-center">
                  <svg class="w-6 h-6 text-blue-200 mr-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.243-4.243a8 8 0 1111.314 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
                  <span>{address}</span>
                </div>
              )}
            </div>
          </div>
        </div>

        <!-- Right Side - Form -->
        <div class="p-10 md:w-3/5 bg-white">
          <form id="whatsapp-contact-form" class="space-y-6" data-whatsapp={whatsapp}>
            <div>
              <label for="name" class="block text-sm font-medium text-gray-700">Nome Completo</label>
              <div class="mt-1">
                <input type="text" name="name" id="name" required class="py-3 px-4 block w-full shadow-sm focus:ring-primary focus:border-primary border-gray-300 rounded-lg text-gray-900 border" placeholder="João da Silva">
              </div>
            </div>
            
            <div>
              <label for="email" class="block text-sm font-medium text-gray-700">E-mail</label>
              <div class="mt-1">
                <input type="email" name="email" id="email" class="py-3 px-4 block w-full shadow-sm focus:ring-primary focus:border-primary border-gray-300 rounded-lg text-gray-900 border" placeholder="joao@exemplo.com">
              </div>
            </div>

            <div>
              <label for="message" class="block text-sm font-medium text-gray-700">Mensagem</label>
              <div class="mt-1">
                <textarea id="message" name="message" rows="4" required class="py-3 px-4 block w-full shadow-sm focus:ring-primary focus:border-primary border-gray-300 rounded-lg text-gray-900 border" placeholder="Como podemos ajudar?"></textarea>
              </div>
            </div>

            <div>
              <button type="submit" class="w-full inline-flex justify-center py-3 px-6 border border-transparent shadow-sm text-base font-medium rounded-lg text-white bg-primary hover:bg-primary/90 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-primary transition-colors">
                {contatoData.cards?.formSubmitText || "Enviar Mensagem"}
              </button>
            </div>
          </form>

          <script is:inline>
            document.getElementById('whatsapp-contact-form')?.addEventListener('submit', function(e) {
              e.preventDefault();
              const form = e.target;
              const name = document.getElementById('name').value;
              const email = document.getElementById('email').value;
              const message = document.getElementById('message').value;
              const waNumber = form.getAttribute('data-whatsapp');
              
              let text = `Olá! Meu nome é *${name}*.\n`;
              if (email) text += `Meu e-mail de contato é: ${email}\n\n`;
              text += `*Mensagem:*\n${message}`;
              
              const encodedText = encodeURIComponent(text);
              const whatsappUrl = `https://wa.me/${waNumber}?text=${encodedText}`;
              
              window.open(whatsappUrl, '_blank');
            });
          </script>
        </div>

      </div>
      
      {contatoData.googleMapsUrl && (
        <div class="mt-12 rounded-3xl overflow-hidden shadow-xl h-96 w-full">
          <iframe 
            src={contatoData.googleMapsUrl} 
            width="100%" 
            height="100%" 
            style="border:0;" 
            allowfullscreen="" 
            loading="lazy" 
            referrerpolicy="no-referrer-when-downgrade"
          ></iframe>
        </div>
      )}
      
    </div>
  </div>
</BaseLayout>
